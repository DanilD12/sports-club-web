@model Stalika.Web.ViewModels.Admin.AdminEquipmentEditViewModel

@{
    bool isEdit = ViewBag.IsEdit == true;
    ViewData["Title"] = isEdit ? "Редактирование инвентаря" : "Добавление инвентаря";
}

<h2>@ViewData["Title"]</h2>

<form method="post" asp-action="@(isEdit ? "EditEquipment" : "CreateEquipment")">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" style="color:red; margin-bottom:12px;"></div>

    <div style="margin-bottom:12px;">
        <label asp-for="EquipmentName">Название</label><br />
        @if (isEdit)
        {
            <input asp-for="EquipmentName" style="width:320px;" readonly />
            <div style="font-size:13px; color:#666; margin-top:4px;">
                Название не редактируется, так как используется как ключ.
            </div>
        }
        else
        {
            <input asp-for="EquipmentName" style="width:320px;" />
        }
        <span asp-validation-for="EquipmentName" class="validation-text"></span>
    </div>

    <div style="margin-bottom:12px;">
        <label asp-for="Type">Тип</label><br />
        <input asp-for="Type" style="width:320px;" />
        <span asp-validation-for="Type" class="validation-text"></span>
    </div>

    <div style="margin-bottom:12px;">
        <label asp-for="Quantity">Количество</label><br />
        <input asp-for="Quantity" type="number" min="0" style="width:220px;" />
        <span asp-validation-for="Quantity" class="validation-text"></span>
    </div>

    <div style="margin-bottom:12px;">
        <label asp-for="PricePerHour">Цена за час</label><br />
        <input asp-for="PricePerHour" type="number" step="0.01" min="0" style="width:220px;" />
        <span asp-validation-for="PricePerHour" class="validation-text"></span>
    </div>

    <div style="display:flex; gap:10px; margin-top:18px;">
        <button type="submit">Сохранить</button>
        <a asp-action="Equipment" class="btn">Назад</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}