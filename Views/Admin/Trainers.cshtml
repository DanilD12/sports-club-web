@model List<Stalika.Web.Entities.Trainer>

@{
    ViewData["Title"] = "Управление тренерами";
}

<h2>Управление тренерами</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div style="color: green; margin-bottom: 12px; font-weight: 600;">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div style="color: red; margin-bottom: 12px; font-weight: 600;">
        @TempData["ErrorMessage"]
    </div>
}

<div style="margin-bottom:16px;">
    <a asp-action="CreateTrainer" class="btn">Добавить тренера</a>
</div>

@if (!Model.Any())
{
    <p>Тренеров пока нет.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>ID тренера</th>
                <th>Пользователь</th>
                <th>Email</th>
                <th>Ставка</th>
                <th>Квалификация</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.TrainerId</td>
                    <td>@($"{item.User?.FirstName} {item.User?.LastName}".Trim())</td>
                    <td>@item.User?.Email</td>
                    <td>@((item.HourlyRate ?? 0).ToString("0.##")) ₽</td>
                    <td>@(string.IsNullOrWhiteSpace(item.Qualification) ? "—" : item.Qualification)</td>
                    <td>
                        <div style="display:flex; gap:8px; flex-wrap:wrap;">
                            <a asp-action="EditTrainer" asp-route-id="@item.TrainerId" class="btn">Редактировать</a>

                            <form asp-action="DeleteTrainer" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.TrainerId" />
                                <button type="submit" onclick="return confirm('Удалить тренера?');">Удалить</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}