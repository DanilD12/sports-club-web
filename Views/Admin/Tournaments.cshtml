@model List<Stalika.Web.Entities.Tournament>

@{
    ViewData["Title"] = "Управление турнирами";
    var counts = ViewBag.ParticipantCounts as Dictionary<int?, int> ?? new Dictionary<int?, int>();
}

<h2>Управление турнирами</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div style="color: green; margin-bottom: 12px; font-weight: 600;">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div style="color: red; margin-bottom: 12px; font-weight: 600;">
        @TempData["ErrorMessage"]
    </div>
}

<div style="margin-bottom:16px;">
    <a asp-action="CreateTournament" class="btn">Создать турнир</a>
</div>

@if (!Model.Any())
{
    <p>Турниров пока нет.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Название</th>
                <th>Организатор</th>
                <th>Дата</th>
                <th>Участников</th>
                <th>Макс.</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var currentCount = counts.ContainsKey(item.TournamentId) ? counts[item.TournamentId] : 0;

                <tr>
                    <td>@item.TournamentId</td>
                    <td>@item.TournamentName</td>
                    <td>@item.Organizer</td>
                    <td>@item.Date.ToString("dd.MM.yyyy")</td>
                    <td>@currentCount</td>
                    <td>@item.MaxParticipants</td>
                    <td>
                        <div style="display:flex; gap:8px; flex-wrap:wrap;">
                            <a asp-action="EditTournament" asp-route-id="@item.TournamentId" class="btn">Редактировать</a>

                            <form asp-action="DeleteTournament" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.TournamentId" />
                                <button type="submit" onclick="return confirm('Удалить турнир?');">Удалить</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}